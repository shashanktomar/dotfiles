{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": []
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "feature-dev@claude-code-plugins": true,
    "document-skills@anthropic-agent-skills": true,
    "superpowers@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": false,
  "permissions": {
    "allow": ["mcp__pencil"]
  }
}
